# ============================================
# BananaWatch Environment Variables
# Copy to .env.local and fill in values
# ============================================

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://..."

# NextAuth.js
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (reuse from JobPilot or create new)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OpenAI API (reuse from JobPilot)
OPENAI_API_KEY="sk-..."
